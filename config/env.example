###############################################################################
# FREE CLAUDE CODE - ENVIRONMENT CONFIGURATION
# ============================================================================
# This file defines all available providers and configuration options.
# Copy this to .env and add your API keys to get started.
#
# QUICK START:
# 1. cp config/env.example .env
# 2. Add at least one API key from any provider below
# 3. Set MODEL_OPUS, MODEL_SONNET, MODEL_HAIKU to your preferred models
# 4. Run: uv run uvicorn server:app --host 0.0.0.0 --port 8082
#
# PROVIDER FORMAT:
# All models use: provider_prefix/path/to/model
# Example: nvidia_nim/z-ai/glm4.7, open_router/deepseek/deepseek-r1:free
#
# SUPPORTS 31+ PROVIDERS:
# Free/Paid: NVIDIA NIM, OpenRouter, Groq, Together, DeepInfra, HuggingFace,
#            Replicate, Fireworks, Cohere, Mistral, Perplexity, Cerebras,
#            SambaNova, TextSynth, Novita, Predibase, RunPod, Google, xAI,
#            Anthropic, OpenAI, AI21, Anyscale, Custom, Kilo Gateway, 
#            OpenCode Zen
# Local Only: Ollama, LM Studio, llama.cpp, VLLM
#
# AUTHENTICATION: Optional ANTHROPIC_AUTH_TOKEN (use with public proxies)
# MESSAGING: Discord and Telegram bot support
# VOICE: Voice transcription via Whisper (local or NVIDIA NIM)
###############################################################################

###############################################################################
# PROVIDER API KEYS & CONFIGURATION
# Format: provider_prefix/model/name (e.g., nvidia_nim/z-ai/glm4.7)
###############################################################################

## RECOMMENDED FREE/PAID OPTIONS ##

# NVIDIA NIM (40 req/min free) - RECOMMENDED FOR DAILY USE
NVIDIA_NIM_API_KEY=""
NIM_ENABLE_THINKING=true  # Enable for thinking models (kimi, nemotron)

# OpenRouter (hundreds of open-source models, free & paid)
OPENROUTER_API_KEY=""

# Groq (free tier, fast inference)
GROQ_API_KEY=""

# Together AI (open-source models, free tier)
TOGETHER_API_KEY=""

# DeepInfra (diverse models, free tier)
DEEPINFRA_API_KEY=""

# HuggingFace (free inference API)
# Note: HuggingFace requires model ID in the base URL
# Format: https://api-inference.huggingface.co/models/{model_id}/v1
# Example: https://api-inference.huggingface.co/models/meta-llama/Llama-2-7b-hf/v1
HUGGINGFACE_API_KEY=""
HUGGINGFACE_BASE_URL=""  # Set full URL with model_id for HuggingFace

# Replicate (model hosting, free tier)
REPLICATE_API_KEY=""

# Fireworks (fast inference, free tier)
FIREWORKS_API_KEY=""

## OTHER PROVIDERS ##

# AI21 (Jurassic models)
AI21_API_KEY=""

# Anyscale (Ray-based serving)
ANYSCALE_API_KEY=""

# Cohere (Command models, RAG optimization)
COHERE_API_KEY=""

# Mistral (European models, privacy-focused)
MISTRAL_API_KEY=""

# Perplexity (search-enhanced responses)
PERPLEXITY_API_KEY=""

# Cerebras (fast inference, wafer-scale)
CEREBRAS_API_KEY=""

# SambaNova (enterprise AI, custom models)
SAMBANOVA_API_KEY=""

# TextSynth (budget-friendly inference)
TEXTSYNTH_API_KEY=""

# Novita (creative AI, multimodal)
NOVITA_API_KEY=""

# Predibase (fine-tuning, model management)
PREDIBASE_API_KEY=""

# RunPod (GPU cloud, serverless inference)
RUNPOD_API_KEY=""

# Google (PaLM, Gemini)
GOOGLE_API_KEY=""

# xAI (Grok models)
XAI_API_KEY=""

# Kilo Gateway (API gateway)
KILO_GATEWAY_API_KEY=""

# OpenCode Zen (open-source platform)
OPENCODE_ZEN_API_KEY=""

# Anthropic (Claude models - included for completeness)
ANTHROPIC_API_KEY=""

# OpenAI (GPT models)
OPENAI_API_KEY=""

# Custom OpenAI-compatible API
CUSTOM_API_KEY=""
CUSTOM_BASE_URL="https://your-api-endpoint.com/v1"

## LOCAL PROVIDERS (no API key required) ##

# LM Studio (local models, no key needed)
LM_STUDIO_BASE_URL="http://localhost:1234/v1"

# Ollama (local models, no key needed)
OLLAMA_BASE_URL="http://localhost:11434/v1"

# llama.cpp (local inference, no key needed)
LLAMACPP_BASE_URL="http://localhost:8080/v1"

# VLLM (local serving, no key needed)
VLLM_BASE_URL="http://localhost:8000/v1"

###############################################################################
# MODEL MAPPING
###############################################################################
# Map Claude models to your preferred provider models
# Format: provider_prefix/model/name
# MODEL is the fallback for unrecognized Claude model requests

# Example: Mix providers for different model sizes
MODEL_OPUS="nvidia_nim/z-ai/glm4.7"
MODEL_SONNET="open_router/arcee-ai/trinity-large-preview:free"
MODEL_HAIKU="open_router/stepfun/step-3.5-flash:free"
MODEL="nvidia_nim/z-ai/glm4.7"  # Fallback model

###############################################################################
# PROVIDER & RATE LIMITING
###############################################################################
# Rate limiting prevents hitting API quotas
PROVIDER_RATE_LIMIT=40
PROVIDER_RATE_WINDOW=60  # Rolling window in seconds
PROVIDER_MAX_CONCURRENCY=5  # Max concurrent requests

# HTTP client timeouts (seconds)
HTTP_READ_TIMEOUT=120
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=2

###############################################################################
# PROXY AUTHENTICATION (Optional)
###############################################################################
# Set a token to require clients to authenticate with the proxy
# If empty (default), no authentication is required (backward compatible)
# If set, clients must provide the same token via ANTHROPIC_AUTH_TOKEN header
ANTHROPIC_AUTH_TOKEN=""

###############################################################################
# MESSAGING PLATFORMS
###############################################################################
# Messaging platform: "discord" | "telegram" (for Discord/Telegram bots)
MESSAGING_PLATFORM="discord"
MESSAGING_RATE_LIMIT=1
MESSAGING_RATE_WINDOW=1

# Discord Bot
DISCORD_BOT_TOKEN=""
ALLOWED_DISCORD_CHANNELS=""  # Comma-separated channel IDs

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
ALLOWED_TELEGRAM_USER_ID=""  # Comma-separated user IDs

###############################################################################
# VOICE NOTE TRANSCRIPTION (Optional)
###############################################################################
VOICE_NOTE_ENABLED=false

# WHISPER_DEVICE: "cpu" | "cuda" | "nvidia_nim"
#   - "cpu" or "cuda": Local Hugging Face Whisper (offline, free)
#                      Install with: uv sync --extra voice_local
#   - "nvidia_nim": NVIDIA NIM Whisper via gRPC (requires NVIDIA_NIM_API_KEY)
#                   Install with: uv sync --extra voice
WHISPER_DEVICE="nvidia_nim"

# WHISPER_MODEL:
#   - Local (cpu/cuda): tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
#   - NVIDIA NIM: nvidia/parakeet-ctc-1.1b-asr, openai/whisper-large-v3
WHISPER_MODEL="openai/whisper-large-v3"

# HuggingFace token (for local voice, if using HF models)
HF_TOKEN=""

###############################################################################
# AGENT CONFIGURATION
###############################################################################
# Claude Code workspace (where files are created/modified)
CLAUDE_WORKSPACE="./agent_workspace"

# Restrict Claude to specific directories (security)
ALLOWED_DIR=""

# Optimizations to reduce API calls
FAST_PREFIX_DETECTION=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true